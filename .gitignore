# macOS
.DS_Store

# Temporary and generated artifacts
tmp/
coverage.out           # go test -coverprofile (also produced by CI)
coverage.html          # go tool cover -html output

# Test artifacts
*.test                 # go test binaries

# Generated images and example outputs
testdata/*.jpg
tmp/outputs/
tmp/examples/
tmp/test-output/

# Compiled binaries / cgo native objects
/example
*.o
*.so
*.dylib

# Editor / IDE
.idea/
.vscode/
*.swp

# Claude Code — personal settings only; shared .claude/settings.json may be committed
.claude/settings.local.json
